OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
OPEN_METEO_AIR_QUALITY_URL=https://air-quality-api.open-meteo.com/v1
OPEN_METEO_ARCHIVE_URL=https://archive-api.open-meteo.com/v1
OPEN_METEO_GEOCODING_URL=https://geocoding-api.open-meteo.com/v1

# Reddit API (optional — app works without it; needed only for dataset building)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=sunset-predictor/1.0 by your_username

# Model paths (relative to backend/ working directory)
MODEL_PATH=trained_models/calibration_model.joblib
MODEL_METADATA_PATH=trained_models/model_metadata.json

# ML blending: 0.0 = pure ML, 1.0 = pure physics
ML_BLEND_ALPHA=0.4

# Default horizon obstruction in degrees (0 = open horizon, 15+ = buildings/mountains)
DEFAULT_HORIZON_OBSTRUCTION_DEG=2.0

# Weather cache TTL in seconds
CACHE_TTL_SECONDS=900

APP_ENV=development

# ── Email / photo submission ──────────────────────────────────────────────────
# Fill these in to enable POST /submit-photo.
# For Gmail: create an App Password at https://myaccount.google.com/apppasswords
# and use SMTP_HOST=smtp.gmail.com, SMTP_PORT=587.
# Leave SMTP_HOST blank to disable the feature.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
DEVELOPER_EMAIL=
